{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "Nix Codespace",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "packages": [
        "alejandra",
        "deadnix",
        "statix",
        "nixfmt",
        "lazygit",
        "nodejs",
        "mcp-nixos"
      ]
    }
  },
  "postCreateCommand": {
    "nix-store": "nix-store --optimize",
    "npm-globals": "mkdir -p $HOME/.npm-global && npm config set prefix $HOME/.npm-global && export PATH=$HOME/.npm-global/bin:$PATH"
  }
}