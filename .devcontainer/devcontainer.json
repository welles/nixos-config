{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "Nix Codespace",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "extraNixConfig": "extra-experimental-features = nix-command flakes",
      "packages": [
        "alejandra",
        "deadnix",
        "statix",
        "nixfmt",
        "lazygit",
        "nodejs",
        "mcp-nixos"
      ]
    }
  },
  "postCreateCommand": {
    "nix-store": "nix-store --optimize",
    "git-rebase": "git config --global pull.rebase true"
    // "npm-globals": "npm config set prefix /home/vscode/.npm-global"
  },
  "containerEnv": {
    "NPM_CONFIG_PREFIX": "/home/vscode/.npm-global"
  },
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.npm-global/bin"
  },
  "mounts": [
    "source=devcontainer-npm-global,target=/home/vscode/.npm-global,type=volume"
  ]
}